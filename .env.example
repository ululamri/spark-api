APP_ENV=development
RUST_LOG=spark_api=info,tower_http=info

SPARK_API_HOST=127.0.0.1
SPARK_API_PORT=8787
SPARK_WEB_ORIGIN=http://127.0.0.1:5173

DATABASE_URL=postgres://spark:spark_dev_password@127.0.0.1:5432/spark
DATABASE_MAX_CONNECTIONS=5

S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET_PUBLIC=spark-public
S3_BUCKET_PRIVATE=spark-private

SPARK_SESSION_COOKIE=spark_session
SPARK_SESSION_TTL_DAYS=14
SPARK_COOKIE_SECURE=false

# Read-only Admin API. Use a long, random value and never commit the real token.
KARYRA_ADMIN_TOKEN=
