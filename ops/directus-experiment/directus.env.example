# Karyra Directus experiment env
# Copy to directus.env on the server and fill strong secrets.

DIRECTUS_IMAGE=directus/directus:11
DIRECTUS_PORT=8055

# Directus core secrets. Generate with: openssl rand -base64 48
SECRET=replace-with-long-random-secret
KEY=replace-with-long-random-key

# First Directus administrator account for the isolated experiment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password

# Public URL should stay local-only until Caddy route is explicitly reviewed.
PUBLIC_URL=http://127.0.0.1:8055

# Directus database, isolated from Spark API production DB.
DIRECTUS_DB_DATABASE=karyra_directus
DIRECTUS_DB_USER=karyra_directus
DIRECTUS_DB_PASSWORD=replace-with-strong-db-password

# Keep realtime off until needed.
WEBSOCKETS_ENABLED=false

# Experiment safety defaults.
TELEMETRY=false
CACHE_ENABLED=false
