{
        # Provider-managed HTTPS mode.
        # The hosting provider terminates public HTTPS before traffic reaches this server.
        # Caddy serves HTTP internally and reverse-proxies to Spark services.
        auto_https off
}

http://{$SPARK_DOMAIN} {
        encode zstd gzip

        handle /v1/* {
                reverse_proxy spark-api:8787
        }

        handle /health/* {
                reverse_proxy spark-api:8787
        }

        handle /health {
                reverse_proxy spark-api:8787
        }

        redir /hub /hub/ 308

        @hubVersion path /hub/_app/version.json
        handle @hubVersion {
                header Cache-Control "no-store"
                uri strip_prefix /hub
                reverse_proxy spark-hub:4174
        }

        @hubImmutable path /hub/_app/immutable/*
        handle @hubImmutable {
                header Cache-Control "public, max-age=31536000, immutable"
                uri strip_prefix /hub
                reverse_proxy spark-hub:4174
        }

        @hubAssets path /hub/_app/*
        handle @hubAssets {
                header Cache-Control "no-cache, must-revalidate"
                uri strip_prefix /hub
                reverse_proxy spark-hub:4174
        }

        @hubFavicon path /hub/favicon.svg
        handle @hubFavicon {
                header Cache-Control "public, max-age=3600"
                uri strip_prefix /hub
                reverse_proxy spark-hub:4174
        }

        @hubPages path /hub/ /hub/*
        handle @hubPages {
                header Cache-Control "no-store"
                reverse_proxy spark-hub:4174
        }

        handle {
                reverse_proxy spark-web:4173
        }

        header {
                X-Content-Type-Options nosniff
                Referrer-Policy strict-origin-when-cross-origin
                -Server
        }
}