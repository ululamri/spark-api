{
	# Provider-managed HTTPS mode.
	# The hosting provider terminates public HTTPS before traffic reaches this server.
	# Caddy serves HTTP internally and reverse-proxies to Spark services.
	auto_https off
}

http://{$SPARK_DOMAIN} {
	encode zstd gzip

	handle /v1/* {
		reverse_proxy spark-api:8787
	}

	handle /health/* {
		reverse_proxy spark-api:8787
	}

	handle /health {
		reverse_proxy spark-api:8787
	}

		handle /hub {
		header Cache-Control "no-store"
		redir /hub/ 308
	}

	# Hub is built with PUBLIC_HUB_BASE_PATH=/hub.
	# Page routes keep /hub; static asset requests are mapped to the Hub container asset root.
	handle /hub/_app/version.json {
		header Cache-Control "no-store"
		uri strip_prefix /hub
		reverse_proxy spark-hub:4174
	}

	handle /hub/_app/immutable/* {
		header Cache-Control "public, max-age=31536000, immutable"
		uri strip_prefix /hub
		reverse_proxy spark-hub:4174
	}

	handle /hub/_app/* {
		header Cache-Control "public, max-age=3600"
		uri strip_prefix /hub
		reverse_proxy spark-hub:4174
	}

	handle /hub/favicon.svg {
		header Cache-Control "public, max-age=3600"
		uri strip_prefix /hub
		reverse_proxy spark-hub:4174
	}

	handle /hub/* {
		header Cache-Control "no-store"
		reverse_proxy spark-hub:4174
	}
}