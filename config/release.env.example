# Karyra Spark API release environment example.
# Copy to .env.release on the server and replace every placeholder before use.

APP_ENV=production
RUST_LOG=spark_api=info,tower_http=info

SPARK_API_HOST=0.0.0.0
SPARK_API_PORT=8787
SPARK_WEB_ORIGIN=https://replace-with-spark-domain.example

POSTGRES_DB=spark
POSTGRES_USER=spark
POSTGRES_PASSWORD=replace_with_strong_postgres_password
POSTGRES_PORT=5432
DATABASE_URL=postgres://spark:replace_with_strong_postgres_password@postgres:5432/spark
DATABASE_MAX_CONNECTIONS=10

S3_ENDPOINT=http://minio:9000
S3_BUCKET_PUBLIC=spark-public
S3_BUCKET_PRIVATE=spark-private
MINIO_ROOT_USER=spark_minio
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

SPARK_SESSION_COOKIE=spark_session
SPARK_SESSION_TTL_DAYS=14
SPARK_COOKIE_SECURE=true

# Optional override used by smoke scripts.
API_BASE_URL=http://127.0.0.1:8787
