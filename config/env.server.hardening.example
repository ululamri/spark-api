# Copy config/env.server.example to .env.server and replace all placeholders.
# This file documents the stricter production expectations used by Pass 52 scripts.

APP_ENV=production
RUST_LOG=spark_api=info,tower_http=info

SPARK_API_HOST=0.0.0.0
SPARK_API_PORT=8787
SPARK_WEB_ORIGIN=https://your-real-spark-frontend.example

POSTGRES_DB=spark
POSTGRES_USER=spark
POSTGRES_PASSWORD=replace_with_strong_database_password
POSTGRES_PORT=5432
DATABASE_URL=postgres://spark:replace_with_strong_database_password@postgres:5432/spark
DATABASE_MAX_CONNECTIONS=10

S3_ENDPOINT=http://minio:9000
S3_BUCKET_PUBLIC=spark-public
S3_BUCKET_PRIVATE=spark-private
MINIO_ROOT_USER=spark_minio
MINIO_ROOT_PASSWORD=replace_with_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

SPARK_SESSION_COOKIE=spark_session
SPARK_SESSION_TTL_DAYS=14
SPARK_COOKIE_SECURE=true
