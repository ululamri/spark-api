# Karyra Spark Unified Docker Stack — staging example.
# Copy to config/env.unified.staging and replace all CHANGE_ME values.

APP_ENV=production
RUST_LOG=spark_api=info,tower_http=info

# Public domain used by Caddy.
SPARK_DOMAIN=spark.user.cloudjkt01.com
CADDY_ACME_EMAIL=CHANGE_ME_EMAIL@example.com
HTTP_PORT=80
HTTPS_PORT=443

# Build contexts are relative to infra/docker-compose.unified.staging.yml.
# If spark, spark-api, and hub are sibling directories under /opt/karyra, keep these defaults.
SPARK_API_CONTEXT=..
SPARK_WEB_CONTEXT=../../spark
SPARK_HUB_CONTEXT=../../hub
SPARK_RUNTIME_ENV_FILE=../config/env.unified.staging
SPARK_WEB_RUNTIME_ENV_FILE=../../spark/.env.unified.staging
SPARK_HUB_RUNTIME_ENV_FILE=../../hub/.env.unified.staging

# Public topology for one-domain beta.
SPARK_PUBLIC_ORIGIN=https://spark.user.cloudjkt01.com
PUBLIC_SPARK_APP_URL=https://spark.user.cloudjkt01.com
PUBLIC_SPARK_HUB_URL=https://spark.user.cloudjkt01.com/hub/
PUBLIC_HUB_BASE_PATH=/hub
PUBLIC_SPARK_MODE=production

# Runtime API config.
SPARK_API_HOST=0.0.0.0
SPARK_API_PORT=8787
SPARK_WEB_ORIGIN=https://spark.user.cloudjkt01.com

POSTGRES_DB=spark
POSTGRES_USER=spark
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgres://spark:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/spark
DATABASE_MAX_CONNECTIONS=5

S3_ENDPOINT=http://minio:9000
S3_BUCKET_PUBLIC=spark-public
S3_BUCKET_PRIVATE=spark-private
MINIO_ROOT_USER=spark_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

SPARK_SESSION_COOKIE=spark_session
SPARK_SESSION_TTL_DAYS=14
SPARK_COOKIE_SECURE=true
KARYRA_ADMIN_TOKEN=CHANGE_ME_ADMIN_TOKEN

# Frontend unified stack build/runtime config.
PUBLIC_API_BASE=
PUBLIC_SPARK_API_BASE=

# HTTPS mode. Public HTTPS is terminated by the provider; Caddy proxies HTTP internally.
SPARK_HTTPS_MODE=provider-managed
