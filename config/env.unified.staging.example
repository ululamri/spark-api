# Karyra Spark Unified Docker Stack — staging example.
# Copy to config/env.unified.staging and replace all CHANGE_ME values.

APP_ENV=production
RUST_LOG=spark_api=info,tower_http=info

# Public domain used by Caddy.
SPARK_DOMAIN=spark.user.cloudjkt01.com
CADDY_ACME_EMAIL=CHANGE_ME_EMAIL@example.com
HTTP_PORT=80
HTTPS_PORT=443

# Build contexts are relative to infra/docker-compose.unified.staging.yml.
# If spark and spark-api are sibling directories, keep these defaults.
SPARK_API_CONTEXT=..
SPARK_WEB_CONTEXT=../../spark
SPARK_RUNTIME_ENV_FILE=../config/env.unified.staging

# Runtime API config.
SPARK_API_HOST=0.0.0.0
SPARK_API_PORT=8787
SPARK_WEB_ORIGIN=https://spark.user.cloudjkt01.com

POSTGRES_DB=spark
POSTGRES_USER=spark
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgres://spark:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/spark
DATABASE_MAX_CONNECTIONS=5

S3_ENDPOINT=http://minio:9000
S3_BUCKET_PUBLIC=spark-public
S3_BUCKET_PRIVATE=spark-private
MINIO_ROOT_USER=spark_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

SPARK_SESSION_COOKIE=spark_session
SPARK_SESSION_TTL_DAYS=14
SPARK_COOKIE_SECURE=true
